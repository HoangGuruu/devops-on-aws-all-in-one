# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=yourStrongPwd   # required: root password
MYSQL_DATABASE=reviews              # default database name created during initialization
# MYSQL_USER=appuser                # (optional) create an additional application user
# MYSQL_PASSWORD=appuserPwd         # (optional) password for the user above
# MYSQL_PORT=3306                   # (optional) change the port if needed

# ---------- Details service ----------
DETAILS_VERSION=v1                  # can be v1, v2, etc.
ENABLE_EXTERNAL_BOOK_SERVICE=false  # true/false to enable external book service

# ---------- Ratings service ----------
RATINGS_VERSION=v1                  # multiple versions can run in parallel
# MONGO_HOST=mongodb                # (optional) MongoDB hostname, default is mongodb
# MONGO_PORT=27017                  # (optional) MongoDB port
# RATINGS_LOG_LEVEL=debug           # (optional) log level: info/debug/warn

# ---------- Reviews service ----------
REVIEWS_VERSION=v1                  # reviews service version
ENABLE_RATINGS=true                 # true: enable ratings, false: disable ratings
STAR_COLOR=black                    # star display color: black, red, blue, etc.
# MYSQL_HOST=mysql                  # (optional) MySQL hostname
# MYSQL_PORT=3306                   # (optional) MySQL port
# MYSQL_USER=root                   # (optional) MySQL connection user
# MYSQL_PASSWORD=yourStrongPwd      # (optional) password for the user above

# ---------- Productpage service ----------
FLOOD_FACTOR=0                      # simulate load; higher value = heavier load
DETAILS_HOST=details                # (optional) override details service hostname
RATINGS_HOST=ratings                # (optional) override ratings service hostname
REVIEWS_HOST=reviews                # (optional) override reviews service hostname
# PRODUCTPAGE_LOG_LEVEL=info        # (optional) log level: info/debug/warn

# ---------- Common ----------
# NETWORK_NAME=app-net              # (optional) Docker network name
# SERVICE_VERSION_TAG=latest        # (optional) image build tag